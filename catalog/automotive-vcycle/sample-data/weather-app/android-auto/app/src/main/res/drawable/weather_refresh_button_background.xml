<?xml version="1.0" encoding="utf-8"?>
<!-- Weather app specific refresh button background -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/car_button_primary" />
            <corners android:radius="@dimen/car_button_radius" />
            <stroke android:width="2dp" android:color="@color/car_button_border" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/car_button_primary" />
            <corners android:radius="@dimen/car_button_radius" />
            <stroke android:width="3dp" android:color="@color/car_button_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/car_button_primary" />
            <corners android:radius="@dimen/car_button_radius" />
            <stroke android:width="1dp" android:color="@color/car_button_border" />
        </shape>
    </item>
</selector>
